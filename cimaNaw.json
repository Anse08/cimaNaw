{
  "provider": "CimaNow",
  "mainUrl": "https://cimanow.cc",
  "config": {
    "user_agent": "Mozilla/5.0 (Linux; Android 11) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115 Mobile Safari/537.36",
    "referer": "https://cimanow.cc/",
    "encoding_offset": 87653
  },
  "navigation": [
    {"title": "الرئيسية", "path": "/home"},
    {"title": "الأفلام", "path": "/category/الافلام/"},
    {"title": "المسلسلات", "path": "/category/المسلسلات/"},
    {"title": "أفلام أجنبية", "path": "/category/افلام-اجنبية/"},
    {"title": "مسلسلات أجنبية", "path": "/category/مسلسلات-اجنبية/"},
    {"title": "أفلام عربية", "path": "/category/أفلام-عربية/"},
    {"title": "مسلسلات عربية", "path": "/category/مسلسلات-عربية/"}
  ],
  "selectors": {
    "main": {
      "item": "section[aria-label='posts'] article, .owl-body article",
      "title": "li[aria-label='title'], h2",
      "link": "a",
      "image": "img",
      "img_attr": "data-src",
      "year": "li[aria-label='year']"
      "genre": "li[aria-label='year']"
      
    },
    "series": {
      "is_series_check": "section[aria-label='seasons'], ul#eps",
      "season_container": "section[aria-label='seasons'] ul li",
      "season_title": "a",
      "episode_container": "ul#eps",
      "episode_item": "li a",
      "episode_title": "em",
      "episode_link": "href"
    },
    "player": {
      "decode_key": "hide_my_HTML_",
      "server_list_item": "ul#serversList li",
      "server_attr_id": "data-id",
      "server_attr_index": "data-index",
      "switch_api": "/wp-content/themes/Cima%20Now%20New/core.php?action=switch&index={index}&id={id}",
      "iframe": "iframe",
      "iframe_src": "src",
      "video_regex": "\\[(\\d+p)\\]\\s+(/uploads/[^\"]+\\.mp4)",
      "m3u8_regex": "https?://[^\\s\"']+\\.(?:m3u8|mp4)[^\\s\"']*",
      "is_base64_encoded": true
    }
  },
  "search": {
    "path": "/?s={query}",
    "item_selector": "section article[aria-label='post'] a",
    "title_selector": "li[aria-label='title']",
    "img_selector": "img",
    "img_attr": "data-src"
  }
    }
